<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_split_delivery_truck_wizard_form" model="ir.ui.view">
        <field name="name">split.delivery.truck.wizard.form</field>
        <field name="model">split.delivery.truck.wizard</field>
        <field name="arch" type="xml">
            <form string="Dividir traslado por camiones">
                <group>
                    <field name="picking_id" readonly="1"/>
                    <field name="trucks_already_entered" readonly="1"/>
                    <field name="trucks_in_gate"/>
                    <field name="trucks_total" readonly="1"/>
                </group>
                <group>
                    <field name="message" readonly="1" nolabel="1" colspan="2" widget="text"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="Confirmar"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
