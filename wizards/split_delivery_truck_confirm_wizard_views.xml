<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_split_delivery_truck_confirm_wizard_form" model="ir.ui.view">
        <field name="name">split.delivery.truck.confirm.wizard.form</field>
        <field name="model">split.delivery.truck.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirmar división por camiones">
                <group>
                    <field name="confirmation_message"
                           readonly="1"
                           nolabel="1"
                           colspan="2"
                           widget="text"/>
                </group>
                <group string="Detalle de la división">
                    <field name="picking_id" readonly="1"/>
                    <field name="trucks_already_entered" readonly="1"/>
                    <field name="trucks_in_gate" readonly="1"/>
                    <field name="trucks_total" readonly="1"/>
                </group>
                <footer>
                    <button name="action_confirm_split"
                            type="object"
                            string="Confirmar división"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
