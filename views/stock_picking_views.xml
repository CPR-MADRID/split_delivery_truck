<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_split_delivery_truck" model="ir.ui.view">
        <field name="name">stock.picking.form.split.delivery.truck</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_split_delivery_truck_wizard"
                        type="object"
                        string="Dividir traslado"
                        class="btn-secondary"
                        invisible="picking_type_code != 'incoming' or state in ['done', 'cancel']"/>
            </xpath>
        </field>
    </record>
</odoo>
